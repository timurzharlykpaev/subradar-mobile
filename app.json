{
  "expo": {
    "name": "SubRadar",
    "slug": "subradar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#8B5CF6"
    },
    "scheme": "subradar",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.goalin.subradar",
      "icon": "./assets/images/icon.png",
      "entitlements": {
        "aps-environment": "development"
      },
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.140914936328-hftqahkh20bdie089g2mfdcnuuker4cm"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.140914936328-hftqahkh20bdie089g2mfdcnuuker4cm"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#8B5CF6"
      },
      "package": "com.goalin.subradar",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-av",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b6fbf0f2-a22b-4eb7-8fb7-d03856c94551"
      }
    },
    "owner": "timur98_zkharlyk"
  }
}
