{
  "expo": {
    "name": "SubRadar",
    "slug": "subradar",
    "version": "1.3.2",
    "description": "AI-powered subscription tracker. Add by voice, scan receipts, get reminders before charges, analyze spending across all your subscriptions.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#8B5CF6",
    "githubUrl": "https://github.com/timurzharlykpaev/subradar-mobile",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#11111F"
    },
    "scheme": "subradar",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.goalin.subradar",
      "icon": "./assets/images/icon.png",
      "entitlements": {
        "aps-environment": "production",
        "com.apple.developer.associated-domains": [
          "applinks:subradar.ai",
          "applinks:app.subradar.ai"
        ]
      },
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.1026598677430-8qjldmtstvjo9a9gjsabipo05mo7ci5u"
            ]
          }
        ],
        "CFBundleLocalizations": [
          "en",
          "ru",
          "kk",
          "de",
          "fr",
          "es",
          "zh-Hans",
          "ja",
          "ko"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "SubRadar needs microphone access to add subscriptions by voice.",
        "NSLocalNetworkUsageDescription": "SubRadar needs local network access to connect to the development server.",
        "NSBonjourServices": [
          "_http._tcp"
        ]
      },
      "xcodeproj": {
        "buildSettings": {
          "CODE_SIGN_ALLOW_ENTITLEMENTS_MODIFICATION": "YES"
        }
      },
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F0F1A"
      },
      "splash": {
        "image": "./assets/images/splash.png",
        "resizeMode": "cover",
        "backgroundColor": "#11111F"
      },
      "package": "com.goalin.subradar",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "subradar.ai",
              "pathPrefix": "/app"
            },
            {
              "scheme": "https",
              "host": "app.subradar.ai"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "navigationBarColor": "#0A0A14",
      "navigationBarStyle": "dark"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SubRadar to access your photos to scan receipts.",
          "cameraPermission": "Allow SubRadar to take photos of receipts."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "SubRadar needs microphone access to add subscriptions by voice."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#7C5CFF",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b6fbf0f2-a22b-4eb7-8fb7-d03856c94551"
      }
    },
    "owner": "timur98_zkharlyk"
  }
}
