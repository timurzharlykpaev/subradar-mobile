{
  "expo": {
    "name": "SubRadar AI",
    "slug": "subradar-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C47FF"
    },
    "scheme": "subradar",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.subradar.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6C47FF",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "ai.subradar.mobile"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-av",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
