EXPO_PUBLIC_API_URL=https://api.subradar.ai
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Gmail import (Pro feature) — separate OAuth client from Sign-In with Google.
# Create in Google Cloud Console → Credentials → OAuth 2.0 Client IDs.
# For per-platform precision in production, generate 3 separate IDs (iOS,
# Android, Web). Single shared ID works in dev.
EXPO_PUBLIC_GMAIL_OAUTH_CLIENT_ID_IOS=
EXPO_PUBLIC_GMAIL_OAUTH_CLIENT_ID_ANDROID=
EXPO_PUBLIC_GMAIL_OAUTH_CLIENT_ID_WEB=
