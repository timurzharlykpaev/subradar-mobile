{
  "name": "subradar-mobile",
  "version": "1.3.15",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "start:dev": "EXPO_PUBLIC_API_URL=https://api-dev.subradar.ai/api/v1 expo start --clear",
    "start:prod": "EXPO_PUBLIC_API_URL=https://api.subradar.ai/api/v1 expo start --clear",
    "test:e2e": "bash .maestro/run_all.sh",
    "test:all": "bash scripts/test-all.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "version:patch": "npm version patch --no-git-tag-version && node -e \"const f='app.json';const a=JSON.parse(require('fs').readFileSync(f));a.expo.version=require('./package.json').version;require('fs').writeFileSync(f,JSON.stringify(a,null,2)+'\\n')\"",
    "version:minor": "npm version minor --no-git-tag-version && node -e \"const f='app.json';const a=JSON.parse(require('fs').readFileSync(f));a.expo.version=require('./package.json').version;require('fs').writeFileSync(f,JSON.stringify(a,null,2)+'\\n')\"",
    "version:major": "npm version major --no-git-tag-version && node -e \"const f='app.json';const a=JSON.parse(require('fs').readFileSync(f));a.expo.version=require('./package.json').version;require('fs').writeFileSync(f,JSON.stringify(a,null,2)+'\\n')\"",
    "build:testflight": "git checkout main && git pull origin main && eas build --platform ios --profile testflight --auto-submit",
    "build:production": "git checkout main && git pull origin main && eas build --platform ios --profile production --auto-submit",
    "build:preview": "eas build --platform ios --profile preview",
    "build:android": "eas build --platform android --profile production"
  },
  "dependencies": {
    "@amplitude/analytics-react-native": "^1.5.52",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/metro-runtime": "4.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "^8.8.0",
    "@tanstack/react-query": "^5.80.7",
    "@types/react": "~19.1.10",
    "axios": "^1.9.0",
    "expo": "~54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.10",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.8.18",
    "jest-expo": "~54.0.17",
    "metro": "0.81.5",
    "metro-babel-transformer": "0.81.5",
    "metro-cache": "0.81.5",
    "metro-config": "0.81.5",
    "metro-file-map": "0.81.5",
    "metro-resolver": "0.81.5",
    "metro-runtime": "0.81.5",
    "metro-source-map": "0.81.5",
    "metro-transform-plugins": "0.81.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.8",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-purchases": "^9.14.0",
    "react-native-purchases-ui": "^9.14.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "typescript": "~5.9.2",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "private": true,
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "devDependencies": {
    "@babel/plugin-transform-optional-chaining": "^7.28.6",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "jest": "~29.7.0",
    "ts-jest": "^29.4.6"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "jsx": "react",
            "esModuleInterop": true
          }
        }
      ]
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^expo-secure-store$": "<rootDir>/__mocks__/expo-secure-store.js",
      "^@react-native-async-storage/async-storage$": "<rootDir>/__mocks__/@react-native-async-storage/async-storage.js"
    },
    "globals": {
      "__DEV__": false
    }
  },
  "overrides": {
    "handlebars": ">=4.7.9",
    "lodash": ">=4.18.1",
    "node-forge": ">=1.4.0",
    "react-test-renderer": "19.1.0"
  }
}
